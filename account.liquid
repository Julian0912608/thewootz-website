<div style="max-width:900px;margin:0 auto;padding:72px 48px;min-height:60vh">
  <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:40px;flex-wrap:wrap;gap:12px">
    <h1 style="font-family:var(--font-display);font-size:clamp(2rem,3vw,2.8rem);font-weight:300">
      Hallo, {{ customer.first_name }}
    </h1>
    <a href="{{ routes.account_logout_url }}" style="font-size:.78rem;color:var(--mist);text-decoration:none;letter-spacing:.08em;text-transform:uppercase">Uitloggen</a>
  </div>

  <h2 style="font-family:var(--font-display);font-size:1.4rem;font-weight:400;margin-bottom:20px">Bestellingen</h2>

  {% if customer.orders.size == 0 %}
    <p style="color:var(--mist);margin-bottom:24px">Je hebt nog geen bestellingen geplaatst.</p>
    <a href="{{ routes.collections_url }}/all" class="btn btn--primary">Bekijk de collectie</a>
  {% else %}
    <div style="border:1px solid var(--stone);border-radius:var(--radius);overflow:hidden">
      {% for order in customer.orders %}
        <div style="padding:20px 24px;border-bottom:1px solid var(--stone);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
          <div>
            <div style="font-weight:500;font-size:.9rem;margin-bottom:4px">{{ order.name }}</div>
            <div style="font-size:.78rem;color:var(--mist)">{{ order.created_at | date: '%d %B %Y' }}</div>
          </div>
          <div style="text-align:right">
            <div style="font-family:var(--font-display);font-size:1.1rem;font-weight:600">{{ order.total_price | money }}</div>
            <div style="font-size:.72rem;color:var(--sage);text-transform:uppercase;letter-spacing:.08em">{{ order.financial_status_label }}</div>
          </div>
          <a href="{{ order.customer_url }}" class="btn btn--outline btn--sm">Bekijk bestelling</a>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>
