<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#F5EFE4">

  <title>
    {% if page_title == blank %}{{ shop.name }}{% else %}{{ page_title }} – {{ shop.name }}{% endif %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  <script>
    window.themeData = {
      cartUrl: '{{ routes.cart_url }}',
      shopName: '{{ shop.name | escape }}',
      moneyFormat: '{{ shop.money_format }}'
    };
  </script>

  {% if settings.meta_pixel_id != blank %}
  <script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init','{{ settings.meta_pixel_id }}');
    fbq('track','PageView');
  </script>
  {% endif %}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- CART DRAWER -->
  <div class="cart-overlay" id="cartOverlay" aria-hidden="true"></div>
  <div class="cart-drawer" id="cartDrawer" role="dialog" aria-label="Winkelwagen" aria-hidden="true">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Jouw selectie</h2>
      <button class="cart-drawer__close" id="cartClose" aria-label="Sluit winkelwagen">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="cart-drawer__body" id="cartBody">
      <p class="cart-drawer__empty">Je winkelwagen is nog leeg.</p>
    </div>
    <div class="cart-drawer__footer" id="cartFooter" hidden>
      <div class="cart-drawer__subtotal">
        <span>Subtotaal</span>
        <span id="cartTotal" class="cart-drawer__total-price"></span>
      </div>
      <p class="cart-drawer__shipping-note">Gratis verzending vanaf <strong>€80</strong></p>
      <a href="{{ routes.cart_url }}" class="btn btn--primary btn--full">Afrekenen →</a>
    </div>
  </div>

  <!-- TOAST -->
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
