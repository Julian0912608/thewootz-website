{% if section.settings.show_bar %}
<div class="announcement-bar" role="region" aria-label="Aankondiging">
  {{ section.settings.text }}
  {% if section.settings.link != blank %}
    <a href="{{ section.settings.link }}">{{ section.settings.link_text }}</a>
  {% endif %}
</div>
{% endif %}

{% schema %}
{
  "name": "Aankondigingsbalk",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Toon balk", "default": true },
    { "type": "text", "id": "text", "label": "Tekst", "default": "Gratis verzending boven de €80 —" },
    { "type": "text", "id": "link_text", "label": "Linktekst", "default": "Bekijk de producten" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
