<div style="max-width:480px;margin:0 auto;padding:80px 24px;min-height:60vh">
  <h1 style="font-family:var(--font-display);font-size:2.4rem;font-weight:300;text-align:center;margin-bottom:40px">Inloggen</h1>

  {% form 'customer_login' %}
    {% if form.errors %}
      <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:var(--radius);padding:12px 16px;margin-bottom:20px;font-size:.82rem;color:#dc2626">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div style="margin-bottom:16px">
      <label for="email" style="display:block;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:var(--mocha);margin-bottom:6px;font-weight:500">E-mailadres</label>
      <input type="email" name="customer[email]" id="email" autocomplete="email"
             style="width:100%;padding:13px 18px;border:1.5px solid var(--stone);border-radius:var(--radius);font-family:var(--font-body);font-size:.9rem;background:var(--cream);color:var(--espresso);outline:none;transition:border-color .2s"
             onfocus="this.style.borderColor='var(--espresso)'" onblur="this.style.borderColor='var(--stone)'">
    </div>

    <div style="margin-bottom:24px">
      <label for="password" style="display:block;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:var(--mocha);margin-bottom:6px;font-weight:500">Wachtwoord</label>
      <input type="password" name="customer[password]" id="password" autocomplete="current-password"
             style="width:100%;padding:13px 18px;border:1.5px solid var(--stone);border-radius:var(--radius);font-family:var(--font-body);font-size:.9rem;background:var(--cream);color:var(--espresso);outline:none;transition:border-color .2s"
             onfocus="this.style.borderColor='var(--espresso)'" onblur="this.style.borderColor='var(--stone)'">
    </div>

    <button type="submit" class="btn btn--primary btn--full" style="margin-bottom:12px">Inloggen</button>
    <div style="text-align:center">
      <a href="{{ routes.new_customer_url }}" style="font-size:.8rem;color:var(--mist);text-decoration:none">Nieuw account aanmaken</a>
      &nbsp;·&nbsp;
      <a href="{{ 'recover_password' | routes }}" style="font-size:.8rem;color:var(--mist);text-decoration:none">Wachtwoord vergeten?</a>
    </div>
  {% endform %}
</div>
