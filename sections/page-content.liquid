<article style="max-width:780px;margin:0 auto;padding:72px 48px;min-height:60vh">
  <div class="section-label">{{ page.title }}</div>
  <h1 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:300;margin-bottom:32px">
    {{ page.title }}
  </h1>
  <div class="rte" style="color:var(--mocha);line-height:1.85;font-size:.92rem;font-weight:300">
    {{ page.content }}
  </div>
</article>

<style>
.rte h2 { font-family:var(--font-display);font-size:1.8rem;font-weight:300;margin:32px 0 12px;color:var(--espresso); }
.rte h3 { font-family:var(--font-display);font-size:1.3rem;font-weight:600;margin:24px 0 10px;color:var(--espresso); }
.rte p { margin-bottom:16px; }
.rte ul,.rte ol { margin:0 0 16px 24px; }
.rte li { margin-bottom:6px;line-height:1.75; }
.rte a { color:var(--terra);text-decoration:underline; }
.rte strong { font-weight:600;color:var(--espresso); }
.rte img { border-radius:var(--radius);margin:24px 0; }
@media(max-width:640px){article{padding:48px 16px}}
</style>

{% schema %}
{ "name": "Pagina-inhoud" }
{% endschema %}
