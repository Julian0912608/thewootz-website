<div class="email-funnel fade-up" aria-label="Nieuwsbrief">
  <div class="email-funnel__text">
    <h2>{{ section.settings.title | default: '10% korting op jouw eerste bestelling' }}</h2>
    {% if section.settings.subtitle != blank %}
      <p>{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="email-funnel__form">
    {% form 'customer', id: 'emailFunnelForm' %}
      <input type="hidden" name="contact[tags]" value="newsletter,funnel-10pct">
      <input type="hidden" name="customer[accepts_marketing]" value="true">
      <input
        type="email"
        name="contact[email]"
        class="email-funnel__input"
        placeholder="{{ section.settings.placeholder | default: 'jouw@email.nl' }}"
        required
        aria-label="E-mailadres"
      >
      <button type="submit" class="btn btn--gold">
        {{ section.settings.button_text | default: 'Ja, ik wil 10% korting →' }}
      </button>
    {% endform %}
    {% if section.settings.disclaimer != blank %}
      <p class="email-funnel__disclaimer">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "E-mail funnel",
  "settings": [
    { "type": "text", "id": "title", "label": "Titel", "default": "10% korting op jouw eerste bestelling" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitel", "default": "Schrijf je in voor onze nieuwsbrief en ontvang kooktips, nieuwe producten als eerste en een welkomstkorting." },
    { "type": "text", "id": "placeholder", "label": "Placeholder e-mailinput", "default": "jouw@email.nl" },
    { "type": "text", "id": "button_text", "label": "Knoptekst", "default": "Ja, ik wil 10% korting →" },
    { "type": "text", "id": "disclaimer", "label": "Kleine tekst onder formulier", "default": "Geen spam. Altijd uitschrijfbaar." }
  ],
  "presets": [{ "name": "E-mail funnel" }]
}
{% endschema %}
