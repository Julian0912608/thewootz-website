<article class="product-page" itemscope itemtype="https://schema.org/Product">

  <!-- GALLERY -->
  <div class="product-page__gallery">
    <div class="product-page__gallery-main">
      {% if product.featured_image %}
        <img id="galleryMain"
             src="{{ product.featured_image | image_url: width: 1000 }}"
             alt="{{ product.featured_image.alt | escape }}"
             loading="eager"
             itemprop="image"
             style="width:100%;height:100%;object-fit:cover">
      {% endif %}
    </div>

    {% if product.images.size > 1 %}
      <div class="product-page__gallery-thumbs" style="display:flex;gap:6px;padding:8px;background:var(--parchment)">
        {% for image in product.images %}
          <button class="gallery-thumb{% if forloop.first %} active{% endif %}"
                  data-gallery-thumb
                  data-src="{{ image | image_url: width: 1000 }}"
                  data-alt="{{ image.alt | escape }}"
                  style="width:64px;height:64px;overflow:hidden;border:2px solid {% if forloop.first %}var(--espresso){% else %}transparent{% endif %};border-radius:var(--radius);cursor:pointer;padding:0;background:none">
            <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}" style="width:100%;height:100%;object-fit:cover">
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- INFO -->
  <div class="product-page__info" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
    <meta itemprop="priceCurrency" content="EUR">
    <link itemprop="availability" href="https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">

    {% if product.vendor != blank %}
      <div class="product-page__vendor">{{ product.vendor }}</div>
    {% endif %}

    <h1 class="product-page__title" itemprop="name">{{ product.title }}</h1>

    <div class="product-page__price" itemprop="price" content="{{ product.price | money_without_currency }}">
      {% if product.price_varies %}
        <span style="font-size:1rem;font-weight:300;font-family:var(--font-body)">Vanaf </span>
      {% endif %}
      {{ product.price | money }}
      {% if product.compare_at_price > product.price %}
        <s style="font-size:1.3rem;color:var(--mist);margin-left:8px">{{ product.compare_at_price | money }}</s>
      {% endif %}
    </div>

    <div class="product-page__description" itemprop="description">
      {{ product.description }}
    </div>

    <form class="product-page__form" action="{{ routes.cart_add_url }}" method="post">

      {% if product.variants.size > 1 %}
        {% for option in product.options_with_values %}
          <div class="variant-selector">
            <label class="variant-selector__label">{{ option.name }}</label>
            <div class="variant-options">
              {% for value in option.values %}
                <button type="button"
                        class="variant-option{% if option.selected_value == value %} active{% endif %}"
                        data-option-position="{{ option.position }}"
                        data-value="{{ value | escape }}">
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endif %}

      <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
      <input type="hidden" name="quantity" value="1">

      {% if product.available %}
        <button type="submit"
                class="btn btn--primary product-page__add"
                data-add-to-cart
                data-variant-id="{{ product.first_available_variant.id }}">
          In winkelwagen
        </button>
      {% else %}
        <button type="button" class="btn btn--primary product-page__add" disabled>
          Uitverkocht
        </button>
      {% endif %}
    </form>

    <div class="product-page__meta">
      {% if product.tags.size > 0 %}
        <strong>Tags:</strong> {{ product.tags | join: ', ' }}<br>
      {% endif %}
      <strong>SKU:</strong> {{ product.selected_or_first_available_variant.sku | default: 'N/A' }}<br>
      {% if product.vendor != blank %}
        <strong>Merk:</strong> {{ product.vendor }}
      {% endif %}
    </div>

    <!-- Trust mini -->
    <div style="display:flex;gap:16px;margin-top:24px;flex-wrap:wrap">
      <span style="font-size:.76rem;color:var(--mist)">🚚 Gratis verzending boven €80</span>
      <span style="font-size:.76rem;color:var(--mist)">📋 Onderhoudsgids inbegrepen</span>
    </div>
  </div>

</article>

{% if section.settings.show_recommendations %}
  {% render 'product-recommendations' %}
{% endif %}

{% schema %}
{
  "name": "Productpagina",
  "settings": [
    { "type": "checkbox", "id": "show_recommendations", "label": "Toon aanbevolen producten", "default": true }
  ]
}
{% endschema %}
